# Neon Postgres connection string (pooled).
# Get this from the Neon console or `neonctl connection-string`.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Google AI (Gemini) powers the Game Director + report narration.
# It is ALWAYS called behind a strict schema-validation layer and never returns
# executable code. Children's data is de-identified before any call.
# Get a key at https://aistudio.google.com/apikey  (either var name works).
GOOGLE_API_KEY=""
# GEMINI_API_KEY=""
LLM_MODEL="gemini-2.5-flash"

# Signing secret for the profile cookie (use a long random string in production)
PROFILE_COOKIE_SECRET=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
